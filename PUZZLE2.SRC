ResetRecords   ENTRY

               PushWord #0
               PushWord #0
               PushLong #0
               PushLong #ConfirmMsg
               _AlertWindow

               pla
               cmp #$0
               bne ok

               rts

ok             sep #$20
               longa off

               ldx #0
bcleRestName   lda HighNew,x
               sta >High60,x
               sta >High40,x
               sta >High15,x
               sta >High8,x
               sta >High90,x
               sta >High160,x
               sta >High200,x
               sta >High60bis,x
               sta >High40bis,x
               sta >High15bis,x
               sta >High8bis,x
               sta >High90bis,x
               sta >High160bis,x
               sta >High200bis,x

               inx
               cpx #145
               bne bcleRestName

               rep #$20
               longa on

               ldy #$0
               ldx #6
bcleRestSec    lda #$3030
               sta >Time60,x
               txa
               clc
               adc #8
               tax
               iny
               cpy #70
               bne bcleRestSec

               ldy #$0
               ldx #1
bcleRestHour   lda #$3A30
               sta >Time60,x
               sta >Time40,x
               sta >Time15,x
               sta >Time8,x
               sta >Time90,x
               sta >Time60bis,x
               sta >Time40bis,x
               sta >Time15bis,x
               sta >Time8bis,x
               sta >Time90bis,x
               lda #$3A31
               sta >Time160,x
               sta >Time200,x
               lda #$3A32
               sta >Time160bis,x
               lda #$3A33
               sta >Time200bis,x
               txa
               clc
               adc #8
               tax
               iny
               cpy #5
               bne bcleRestHour

               ldy #$0
               ldx #3
               lda #$3130
               sta Time
bcleRestMin    lda Time
               sta >Time8,x
               sta >Time160,x
               sta >Time8bis,x
               sta >Time160bis,x
               clc
               adc #$400
               sta >Time15,x
               clc
               adc #$1
               sec
               sbc #$500
               sta >Time40,x
               sta >Time15bis,x
               clc
               adc #$500
               sta >Time60,x
               sta >Time200,x
               sta >Time200bis,x
               clc
               adc #$1
               sec
               sbc #$500
               sta >Time90,x
               sta >Time40bis,x
               clc
               adc #$1
               sta >Time60bis,x
               clc
               adc #$1
               sta >Time90bis,x
               txa
               clc
               adc #8
               tax
               lda Time
               clc
               adc #$100
               sta Time
               iny
               cpy #5
               bne bcleRestMin

               jmp SaveHighScores

HighNew        str '1. European Software Partner'
               str '2. European Software Partner'
               str '3. European Software Partner'
               str '4. European Software Partner'
               str '5. European Software Partner'

Time           ds 2

