Save           PushLong MDialogPtr
               PushWord #13
               PushLong #StupidString
               _GetIText

               sep #$30

               LongA Off
               LongI Off

               lda NoHighScore
               tax
               lda TableIndex,x
               tax
               lda StupidString
               clc
               adc #$03
               sta >High1,x
               inx
               inx
               inx
               inx
               ldy #01
savename       lda StupidString,y
               sta >High1,x
               iny
               inx
               cpy #26
               bne savename

fastexit       rep #$30

               LongA On
               LongI On

               jsr MoveRecTblBack

               lda #$FF
               sta NoHighScore

               PushLong MDialogPtr
               _CloseDialog

SaveHighScores lda SoundOn
               sta Temp
               lda #1
               sta SoundOn

               jsl Prodos
               dc i2'$0A'               ; Get_Prefix
               dc i4'parmblock0'
               bcc SetPrefix
               jmp FatalError

SetPrefix      jsl Prodos
               dc i2'$09'               ; Set_Prefix
               dc i4'parmblock'
               bcc Open
               jmp FatalError

Open           jsl Prodos
               dc i2'$10'               ; Open
               dc i4'parmblock1'
               bcc Seek
               cmp #$27
               beq notRecoverable

               lda #0
               jsr ProdosError
               bra Open

NotRecoverable jmp FatalError

Seek           lda parmblock1
               sta parmblock2
               sta parmblock3
               sta parmblock4

               jsl Prodos
               dc i2'$16'               ; Set_Mark
               dc i4'parmblock2'
               bcc Write
               jmp FatalError

Write          jsl Prodos
               dc i2'$13'               ; Write
               dc i4'parmblock3'
               bcc Close
               cmp #$2B
               bne pasRecuperable

               lda #2
               jsr ProdosError
               bcc Write
               jmp Close

PasRecuperable jmp FatalError

Close          jsl Prodos
               dc i2'$14'               ; Close
               dc i4'parmblock4'
               bcc SetPrefix2
               jmp FatalError

SetPrefix2     jsl Prodos
               dc i2'$09'               ; Set_Prefix
               dc i4'parmblock0'
               bcc exit

FatalError     lda #1
               jsr ProdosError

exit           lda Temp
               sta SoundOn

               rts

