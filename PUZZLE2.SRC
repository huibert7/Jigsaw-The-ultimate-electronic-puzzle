****************************************************************
*
* Printer. Printer subroutines
*
****************************************************************
Printer        START
               Using GlobalData
               Using Buffermem
               Using BufferMem2

Choose         ENTRY

               PushWord #0
               _PrChoosePrinter

               pla

               rts

StyleDialog    ENTRY

               PushWord #0
               lda PrintHandle+2
               pha
               lda PrintHandle
               pha
               _PrStlDialog

               pla

               rts

Print          ENTRY

               PEA $0007
               _IntSource

               PushWord #0
               PushWord #0
               PushLong #0
               PushLong #PrintMsg
               _AlertWindow

               pla
               inc a
               cmp #$01
               bne notCancel

               lda finished
               inc a
               cmp #1
               beq donothing

               PEA $0015
               PushLong #Interrupt
               _SetVector

               PEA $0006
               _IntSource

donothing      rts

notCancel      cmp #$03
               bne notColor

               lda #$20
               sta Color
               bra Continue

notColor       lda #$00
               sta Color

Continue       lda ShowingPuzzle
               beq no

               jsl ShowPic
               bra Cont

no             jsl DrawPuzzle

Cont           lda PrintHandle
               ldx PrintHandle+2
               jsr Deref

               sta 0
               stx 2
               ldy #$56
               lda [0],y
               and #$FF00
               sta [0],y
               ldy #$18
               lda [0],y
               ora Color
               sta [0],y

               PushWord #0
               lda PrintHandle+2
               pha
               lda PrintHandle
               pha
               _PrValidate

               pla

               PushLong #0
               lda PrintHandle+2
               pha
               lda PrintHandle
               pha
               PushLong #0
               _PrOpenDoc

               pla
               sta PortHandle
               pla
               sta PortHandle+2

               lda PortHandle+2
               pha
               lda PortHandle
               pha
               PushLong #0
               _PrOpenPage

               lda #180
               sta Rectangle+4

               lda ShowingPuzzle
               beq ShuffledPic

               PushLong #LocInfo
               bra Cont2

ShuffledPic    PushLong #LocInfo2

Cont2          PushLong #rectangle
               PushWord #0
               PushWord #0
               PushWord #0
               _PPToPort

               lda PortHandle+2
               pha
               lda PortHandle
               pha
               _PrClosePage

               lda PortHandle+2
               pha
               lda PortHandle
               pha
               _PrCloseDoc

               lda finished
               cmp #1
               beq donothing2

               PEA $0015
               PushLong #Interrupt
               _SetVector

               PEA $0006
               _IntSource

donothing2     rts

LocInfo        dc i2'0'
               dc i4'Picbuf'
               dc i2'160'
               dc i2'0,0,200,320'

LocInfo2       dc i2'0'
               dc i4'PicBuf2'
               dc i2'160'
               dc i2'0,0,200,320'

rectangle      dc i2'0,0,180,320'
PortHandle     ds 4
Color          ds 2

PrintMsg       dc c'34/Are you using a color ribbon ?'
               dc c'/^Cancel/Yes/No',i1'0'

Deref          ENTRY

               sta 0
               stx 2
               ldy #2
               lda [0],y
               tax
               lda [0]
               rts

               END

****************************************************************
*
* SetUpWindows
*
* Opens the window used by the program.
*
****************************************************************
SetupWindows   START
               using GlobalData
               using Buffermem
               using Buffermem2
               using InstDef

               lda #$00
               sta first

               PushLong #0              ; space for result
               PushLong #Win1ParamBlock
               _NewWindow

               pla
               sta Win1Ptr
               pla
               sta Win1Ptr+2

               rts

Win1ParamBlock anop
           dc    i'Win1End-Win1ParamBlock'
           dc    i2'%0000000000100000' Frame stuff bits make dif types
           dc    i4'WindName'          Ptr to title
           dc    i4'0'                 RefCon
           dc    i2'26,0,190,620'      Full Size (0= default)
           dc    i4'0'                 Color Table Pointer
           dc    i2'0'                 Vertical origin
           dc    i2'0'                 Horizontal origin
           dc    i2'200'               Data ARea Height
           dc    i2'640'               Data Area Width
  n
               dc i4'parmblock0'

               jsl Prodos
               dc i2'$12'               ; Read Wave
               dc i4'parmblock1'

               PushLong #PicBuf
               PushWord #$0
               PushWord #$8000
               _WriteRamBlock
               ErrorDeath 'Writing wave '

               jsl Prodos
               dc i2'$12'               ; Read Wave
               dc i4'parmblock2'

               PushLong #PicBuf
               PushWord #$8000
               PushWord #$8000
               _WriteRamBlock
               ErrorDeath 'Writing wave '

               jsl Prodos
               dc i2'$12'               ; Read Instruments
               dc i4'parmblock3'

Close          jsl Prodos
               dc i2'$14'               ; Close
               dc i4'parmblock4'
               bcc Ok

FatalError     jmp ProgramDeath

Ok             rts

MyFullPathname str '1/Music/SndSmith.DOC'

parmblock      ds 2                     ; ref_num
pathname       dc i4'MyFullPathname'    ; pathname
iobuffer       ds 4                     ; io_buffer

parmblock0     ds 2                     ; ref_num
               dc i4'2'                 ; position

parmblock1     ds 2                     ; ref_num
               dc i4'PicBuf'            ; data_buf
               dc i4'$8000'             ; request_count
               ds 4                     ; transfer_count

parmblock2     ds 2                     ; ref_num
               dc i4'PicBuf'            ; data_buf
               dc i4'$8000' Click

               PEA $0015
               PushLong #Interrupt
               _SetVector

               PEA $0006
               _IntSource

               stz FirstClick

               lda TwoPlayFlag
               bne NotFirstClick

               lda Size2
               sta Size
               jsr RestartEntry
               stz FirstClick
               lda #$01
               sta first

NotFirstClick  stz HowManyCorrect
               jsr DrawAllSizes

               ldx #$00
bcle2          lda >picbuf2,x
               sta $E12820,x
               inx
               inx
               cpx #$7080
               bcc bcle2
               bra CalcPercent

CalcPercent    lda HowManyCorrect
               asl a
               asl a
               pha
               lda Size
               asl a
               tax
               pla
               clc
               adc >IndexPercent,x
               tax

               sep #$20
               longa off

               ldy #1
bclePercent    lda >PercentTable60,x
               sta PercentStr,y
               inx
               iny
               cpy #5
               bne bclePercent

               rep #$20
               longa on

               PushLong #0
               _GetPort

               lda GlobalPort+2
               pha
               lda GlobalPort
               pha
               _SetPort

               PushWord #222
               PushWord #10
               _MoveTo

               PushLong #PercentStr
               _DrawString

               _SetPort

               lda HowManyCorrect
               cmp CurrentCorrect
               bcc noOle
               beq noOle

               lda BeepOn
               bne noOle

               jsr Beep

noOle          lda HowManyCorrect
               sta CurrentCorrect

               lda PercentStr+3
               xba
               cmp #'0.'
               bne pasgagne2

               lda finished
               beq gagne
pasgagne2      jmp pasgagne

gagne          _InitCursor
               _ShowCursor

               PEA $0007
               _IntSource

               PushLong #0
               _GetPort

               lda GlobalPort+2
               pha
               lda GlobalPort
               pha
               _SetPort

               PushWord #262
               PushWord #10
               _MoveTo

               lda Player
               cmp #$02
               beq ShowTime2

               PushLong #CurrTime
               _DrawString

               bra TimeShowed

ShowTime2      PushLong #CurrTime2
               _DrawString

TimeShowed     _SetPort

               lda #$01
               sta finished

               PushWord #$FF7F
               PushWord #4
               _SetMenuFlag

               PushWord #266
               _EnableMItem

               PushWord #267
               _EnableMItem

               PushWord #274
               _DisableMItem

               lda BeepOn
               beq SayCongratula
               jmp TaGueule

SayCongratula  sei

               lda #38
               asl a
               tax
               lda >FreqTable,x
               sta Temp

               sep #$20
               longa off

bcleWait2      lda >$E1C03C
               bmi bcleWait2
               ora #%00100000
               and #%10111111
               sta >$E1C03C

               lda #10
               sta >$E1C03E
               lda Temp
               sta >$E1C03D             ; Frequency low 5
               lda #$20+10
               sta >$E1C03E
               lda Temp+1
               sta >$E1C03D             ; Frequency high 5
               lda #$40+10
               sta >$E1C03E
               lda #170
               sta >$E1C03D             ; Volume 5
               lda #$80+10
               sta >$E1C03E
               lda #$80
               sta >$E1C03D             ; Wave Adress 5
               lda #$C0+10
               sta >$E1C03E
               lda #$36
               sta >$E1C03D             ; Wave Size 5
               lda #$A0+10
               sta >$E1C03E
               lda #$02
               sta >$E1C03D             ; Control register 5

               rep #$20
               longa on

               cli

TaGueule       jsr ShowWinDialog
               jsr TestHighScore

pasgagne       _InitCursor
               _ShowCursor

fin            rtl

DrawAllSizes   lda #$00
               sta piece
               sta ShowingPuzzle
               sta IndexTemp
               lda #0
               sta line
               lda Line
               sta Line2
               lda Width
               lsr a
               sta TempWidth

loop           lda #1
               sta Correct
               lda #0
               sta Ligne2
               lda piece
               asl a
               tax
               lda >tablepuz0,x
               sta piece2
               lda >tableflip,x
               beq NoFlip
               brl Flip
NoFlip         lda piece2
bcle0          cmp horizPieces
               bcc endbcle0
               pha
               lda ligne2
               clc
               adc heigh
               sta ligne2
               pla
               sec
               sbc horizPieces
               bra bcle0
endbcle0       pha
               lda ligne2
               clc
               adc heigh
               sta yend2
               stz Index2
               pla
bcle1          beq endbcle1
               pha
               lda Index2
               clc
               adc width
               sta Index2
               pla
               dec a
               bra bcle1
endbcle1       lda line2
               sta ligne
               clc
               adc heigh
               sta yend
               lda IndexTemp
               sta index
loop2          lda ligne
               asl a
               tax
               lda >tablelignes,x
               clc
               adc index
               sta buf1
               lda ligne2
               asl a
               tax
               lda >tablelignes,x
               clc
               adc index2
               sta buf2
               ldx #$00
loop3          ldy buf2
               phx
               tyx
               lda >picbuf,x
               plx
               iny
               iny
               sty buf2
               ldy buf1
               phx
               tyx
               sta >picbuf2,x
               cmp >picbuf,x
               beq Equal60
               stz Correct
Equal60        plx
               iny
               iny
               sty buf1
               inx
               cpx TempWidth
               bne loop3
               inc ligne
               inc ligne2
               lda ligne2
               cmp yend2
               bne loop2
               lda HowManyCorrect
               clc
               adc Correct
               sta HowManyCorrect
               lda Piece
               asl a
               tax
               lda Correct
               sta >CorrectTable,x
               inc piece
               lda IndexTemp
               clc
               adc Width
               sta IndexTemp
               cmp #160
               bne NotEnd
               stz IndexTemp
               lda line2
               clc
               adc heigh
               sta Line2
               cmp #180
               bcs end60
NotEnd         jmp loop

end60          _HideCursor

               rts

Flip           lda piece2
bcleLigne      cmp horizPieces
               bcc endbcleLigne
               pha
               lda ligne2
               clc
               adc heigh
               sta ligne2
            
               dc i1'0,0,0,0,0,0'             ; idem

Instrument6    dc i1'0,0,0'                   ; enveloppe
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'                   ; fill out 8 stages with 0's
               dc i1'0'                       ; release segment - 1
               dc i1'0'                       ; priority inc
               dc i1'0'                       ; pitch bend range
               dc i1'0'                       ; slight vibrato
               dc i1'0'                       ; vibrato speed
               dc i1'0'                       ; spare
AWaveCount6    dc i1'0'                       ; number of waveptrs for osc A
BWaveCount6    dc i1'0'                       ; number of waveptrs for osc B
WaveLists6     dc i1'0,0,0,0,0,0'             ; topkey,addr,size,ctrl,pitch
               dc i1'0,0,0,0,0,0'             ; idem
               dc i1'0,0,0,0,0,0'             ; idem
               dc i1'0,0,0,0,0,0'             ; idem   this size supports
               dc i1'0,0,0,0,0,0'             ; idem   up to 5 wave lists
               dc i1'0,0,0,0,0,0'             ; idem   for each wave.
               dc i1'0,0,0,0,0,0'             ; idem
               dc i1'0,0,0,0,0,0'             ; idem
               dc i1'0,0,0,0,0,0'             ; idem
               dc i1'0,0,0,0,0,0'             ; idem

Instrument7    dc i1'0,0,0'                   ; enveloppe
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'
               dc i1'0,0,0'                   ; fill out 8 stages with 0's
               dc i1'0'                       ; release segment - 1
               dc i1'0'                       ; priority inc
               dc i1'0'                       ; pitch bend range
               dc i1'0'                       ; slight vi PushLong #0
               PushLong #PuzzleStr
               _AlertWindow

               pla
               clc

               rts

WrtPrctStr     dc c'25/The disk is write protected/^Try again/Cancel',i1'0'
FilenotFnd     dc c'26/Please insert program disk/^Ok',i1'0'
IOErrStr       dc c'25/Input-output error. Check disk/^Ok',i1'0'
PuzzleStr      dc c'36/Please insert the disk that contains the puzzle you'
               dc c' want to load./^Ok',i1'0'

               END

*******************************PushLong #0              ; output
               PushLong #DRect
               PushWord #True           ; visible
               PushLong #0              ; refcon
               _NewModalDialog

               pla
               sta MDialogPtr
               pla
               sta MDialogPtr+2

               PushLong MDialogPtr
               PushWord #1
               PushLong #ButtonRect
               PushWord #ButtonItem
               PushLong #ButtonText
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #2
               PushLong #TextRect1
               PushWord #StatText+ItemDisable
               PushLong #Text1
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #3
               PushLong #TextRect2
               PushWord #StatText+ItemDisable
               PushLong #Text2
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #4
               PushLong #TextRect3
               PushWord #StatText+ItemDisable
               PushLong #Text3
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #5
               PushLong #TextRect4
               PushWord #StatText+ItemDisable
               PushLong #Text4
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #6
               PushLong #TextRect5
               PushWord #StatText+ItemDisable
               PushLong #Text5
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               sep #$30

               LongA Off
               LongI Off

               lda diffhour
               and #%00001111
               clc
               adc #$30
               sta Timestr+1

               lda diffmin
               and #%00001111
               clc
               adc #$30
               sta Timestr+4

               lda diffmin
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Timestr+3

               lda diffsec
               and #%00001111
               clc
               adc #$30
               sta Timestr+7

               lda diffsec
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Timestr+6

               lda penalty
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Text6+10

               lda penalty
               and #%00001111
               clc
               adc #$30
               sta text6+11

               rep #$30

               LongA On
               LongI On

               PushLong MDialogPtr
               PushWord #7
               PushLong #TimeRect
               PushWord #StatText+ItemDisable
               PushLong #TimeStr
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               ldx penalty
               lda #$00
               sta penalsec
               sta penalmin
bcleconv       cpx #$00
               beq exitbcle
               sed
               clc
               lda penalsec
               adc #$10
               sta penalsec
               cmp #$60
               bne ok
               lda #$00
               sta penalsec
               clc
               lda penalmin
               adc #$01
               sta penalmin
ok             txa
               sec
               sbc #$01
               tax
               cld
               bra bcleconv

exitbcle       sep #$30

               LongA Off
               LongI Off

               lda penalmin
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Text6+28

               lda Penalmin
               and #%00001111
               clc
               adc #$30
               sta Text6+29

               lda penalsec
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Text6+31

               lda Penalsec
               and #%00001111
               clc
               adc #$30
               sta Text6+32

               rep #$30

               LongA On
               LongI On

               PushLong MDialogPtr
               PushWord #8
               PushLong #TextRect6
               PushWord #StatText+ItemDisable
               PushLong #Text6
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushLong MDialogPtr
               PushWord #9
               PushLong #TextRect7
               PushWord #StatText+ItemDisable
               PushLong #Text7
               PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               sed

               lda diffmin
               clc
               adc penalmin
               sta totalmin

               lda diffsec
               clc
               adc penalsec
               sta totalsec
               cmp #$60
               bcc ok2

               sec
               sbc #$60
               sta totalsec
               clc
               lda totalmin
               adc #$01
               sta totalmin

ok2            lda totalmin
               cmp #$60
               bcc ok3

               sec
               sbc #$60
               sta totalmin
               inc diffhour

ok3            cld

               sep #$30

               LongA off
               LongI off

               lda diffhour
               and #%00001111
               clc
               adc #$30
               sta Text8+1

               lda totalmin
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Text8+3

               lda totalmin
               and #%00001111
               clc
               adc #$30
               sta Text8+4

               lda totalsec
               lsr a
               lsr a
               lsr a
               lsr a
               clc
               adc #$30
               sta Text8+6

               lda totalsec
               and #%00001111
               clc
               adc #$30
               sta Text8+7

               rep #$30

               LongA on
tHandle     ds 4
Color          ds 2

PrintMsg       dc c'34/Are you using a color ribbon ?'
               dc c'/^Cancel/Yes/No',i1'0'

Deref          ENTRY

               sta 0
               stx 2
               ldy #2
               lda [0],y
               tax
               lda [0]
               rts

               END

****************************************************************
*
* SetUpWindows
*
* Opens the window used by the program.
*
********************************************************          PushWord #0              ; new field
               PushWord #0
               PushLong #0
               _NewDItem

               PushWord #0              ; result
               PushLong #0
               _ModalDialog

               pla

               PushLong MDialogPtr
               _CloseDialog

               ldx #$00
finalbcle      lda Text8,x
               sta FinalTime,x
               inx
               inx
               cpx #$08
               bne finalbcle

noproblem      rts

DRect          dc i'35,30,180,280'

TextRect1      dc i'15,10,27,280'
Text1          str 'Congratulations, you solved'
TextRect2      dc i'27,10,39,280'
Text2          str 'this puzzle but there are many'
TextRect3      dc i'39,10,51,280'
Text3          str 'others on this disk. Will you be'
TextRect4      dc i'51,10,63,280'
Text4          str 'able to solve them all ?'
TextRect5      dc i'68,10,80,166'
Text5          str 'Time to solve puzzle: '
TimeRect       dc i'68,167,80,280'
timestr        str '0:00:00'
TextRect6      dc i'80,10,92,280'
Text6          str 'Penalty: 00 * 10 sec =     00:00'
TextRect7      dc i'92,164,100,280'
Text7          str '------'
TextRect8      dc i'104,167,116,280'
Text8          str '0:00:00'
TextRect9      dc i'104,40,114,160'
Text9          str 'Final time:'

ButtonRect     dc i'122,147,0,0'

ButtonText     str 'Continue'

MDialogPtr     ds 4

               END

*****************************************************************
*
* ShowHighScores2
*
*****************************************************************
ShowHighScores2 START
               Using GlobalData
               Using BufferMem

               jsr MoveRecTbl

               lda #$FF
               sta NoHighScore
               jsr ShowHighScores

               rts

MoveRecTbl     ENTRY

               lda Size
               ldx FlipMode
               beq NotFlipMode
               clc
               adc #7
NotFlipMode    asl a
               tax
               lda >HighIndex,x
               tax

               sep #$20

               longA Off

               ldy #$00
bclemove       lda >High60,x
               phx
               tyx
               sta >High1,x
               plx
               inx
               iny
               cpy #145
               bne bclemove

               rep #$20

               LongA On

               lda Size
               ldx FlipMode
               beq NotFlipMode2
               clc
               adc #7
NotFlipMode2   asl a
               tax
               lda >TimeIndex,x
               tax

               sep #$20

               longA Off

               ldy #$00
bclemove2      lda >Time60,x
               phx
               tyx
               sta >Time1,x
               plx
               inx
               iny
               cpy #40
               bne bclemove2

               rep #$20

               LongA On

               rts

MoveRecTblBack ENTRY

               lda Size
               ldx FlipMode
               beq NotFlipMode3
               clc
               adc #7
NotFlipMode3   asl a
               tax
               lda >HighIndex,x
               tax

               sep #$20

               longA Off

               ldy #$00
bclemove3      phx
               tyx
               lda >High1,x
               plx
               sta >High60,x
               inx
               iny
               cpy #145
               bne bclemove3

               rep #$20

               LongA On

               lda Size
               ldx FlipMode
               beq NotFlipMode4
               clc
               adc #7
NotFlipMode4   asl a
               tax
               lda >TimeIndex,x
               tax

               sep #$20

               longA Off

               ldy #$00
bclemove4      phx
               tyx
               lda >Time1,x
               plx
               sta >Time60,x
               inx
               iny
               cpy #40
               bne bclemove4

               rep #$20

               LongA On

               rts

               END

*****************************************************************
*
* ShowHighScores
*
* Brings up the High-Score box and waits until button press until
* it puts it away.
*
*****************************************************************
ShowHighScores START
               using globalData
               using BufferMem

               sep #$20

               longA Off

               lda Size
               tax
               lda ZeroNumber,x
               sta >TitleStr+14
               lda FirstNumber,x
               sta >TitleStr+15
               lda SecondNumber,x
               sta >TitleStr+16
               lda #24
               sta >TitleStr
               lda FlipMode
               beq ShortMsg

               lda #32
               sta >TitleStr

ShortMsg       rep #$20
               LongA On

               PushLong #0              ; output
               PushLong #HighScoreRect
               PushWord #True           ; visible
               PushLong #0              ; refcon
               _NewModalDialog

               pla
               sta MDialogPtr
               pla
               sta MDialogPtr+2

               lda NoHighScore
               cmp #$FF
               bne ShowEditLine
               brl NoEditLine

ShowEditLine   PushLong MDialogPtr
               PushWord #13
               lda NoHighScore
               asl a
               asl a
               tay
               iny
               iny
               lda TableRect,y
               pha
               dey
               dey
               lda TableRect,y
               pha
               PushWord #EditLine+ItemDisable
               PushLong #0
               PushWord #25
               PushWord #0
               PushLong #0
               _NewDItem

NoEditLine     PushLong MDialogPtr
               PushWord #1
               PushLong #ButtonHighRect
               PushWord #ButtonItem
